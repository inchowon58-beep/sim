# 네이버 검색 API (애플리케이션 등록 시 「검색」 선택)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Gemini API (SEO 페이지 자동 생성)
GEMINI_API_KEY=

# 사이트 URL (sitemap, OG 이미지 등)
SITE_URL=https://1977demolition.com

# Vercel 배포 시: Storage → Blob 연결 시 자동 설정 (OIDC)
# BLOB_STORE_ID=store_...
# VERCEL_OIDC_TOKEN=  (배포 시 Vercel이 자동 주입)
# 또는 구형 방식: BLOB_READ_WRITE_TOKEN=

# 선택: Cloudflare R2 (Blob 대신 사용 가능)
# R2_ENDPOINT=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=
