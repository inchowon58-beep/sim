# Canonical·IndexNow 기준 도메인
CANONICAL_BASE_URL=https://dmcmusic.co.kr

# 메인(/) 및 일반 경로 프록시 대상
MAIN_PROXY_TARGET=https://www.agapetstory.co.kr

# 메인·서브경로 agapetstory 프록시 (기본 ON, /admin·키워드 URL 제외)
ENABLE_APP_LEVEL_MAIN_PROXY=true

# 관리자 페이지 경로 (검색 노출 안 함)
ADMIN_PATH=/admin

SITE_NAME=Agapet Story SEO

IMAGE_ASSETS_DIR=public/assets/images
IMAGE_ASSETS_PUBLIC_PATH=/assets/images

INDEXNOW_KEY=your-indexnow-key-here
INDEXNOW_ENABLED=true
