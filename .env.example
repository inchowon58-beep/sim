# 서브도메인 Canonical 기준 URL (끝에 / 없이)
CANONICAL_BASE_URL=https://sub.mydomain.com

# agapetstory 메인 URL (서브페이지 iframe 대상)
MAIN_PROXY_TARGET=https://www.agapetstory.co.kr

# 메인(/)까지 agapetstory 프록시 — 기본 OFF (관리 페이지 유지)
ENABLE_APP_LEVEL_MAIN_PROXY=false

# 사이트 기본명 (OG site_name 등)
SITE_NAME=Agapet Story SEO

# 이미지 에셋 — 로컬 폴더 (프로젝트 루트 기준)
IMAGE_ASSETS_DIR=public/assets/images
IMAGE_ASSETS_PUBLIC_PATH=/assets/images

# IndexNow — 네이버·Bing 실시간 색인 제출
INDEXNOW_KEY=your-indexnow-key-here
INDEXNOW_ENABLED=true

# INDEXNOW_HOST=sub.mydomain.com
# INDEXNOW_KEY_LOCATION=https://sub.mydomain.com/your-indexnow-key-here.txt
# INDEXNOW_ENDPOINTS=https://api.indexnow.org/indexnow,https://www.bing.com/indexnow,https://searchadvisor.naver.com/indexnow
