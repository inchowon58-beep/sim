# IndexNow (네이버) — 루트에 {KEY}.txt 가 public에 있어야 함 (모든 도메인 공용 가능)
INDEXNOW_KEY=
INDEXNOW_ENDPOINT=https://searchadvisor.naver.com/indexnow

# 관리자 사이트 불러오기 — Vercel과 동일한 워커 시크릿
# (없으면 SEO_PUBLISHER_SECRET 사용)
COLLECTION_WORKER_SECRET=
# SEO_PUBLISHER_SECRET=
# SEO_PUBLISHER_API_BASE=https://sim-seven-woad.vercel.app

# 도메인 목록 (기본: tools/seo-publisher/sites.json)
# SITES_PATH=

# sites.json 없을 때만 쓰는 단일 사이트 폴백 + 동기화 API 기본 주소
SITE_URL=https://sim-seven-woad.vercel.app
BRAND_NAME=아가펫보호소
PHONE=010-0000-0000
SITE_DESIGN=e

# git push로 Vercel 배포
AUTO_PUSH=1
GIT_REMOTE=origin
GIT_BRANCH_MAIN=main
GIT_BRANCH_PRODUCTION=production

# REPO_ROOT=   # exe가 저장소를 못 찾을 때만
