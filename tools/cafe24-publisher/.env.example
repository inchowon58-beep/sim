# 카페24 호스트 (예: ftp.cafe24.com 또는 고객 전용 호스트)
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_PORT=21
FTP_PASSIVE=1

# HTML 업로드 경로 / 루트 sitemap 경로 (카페24 웹루트 기준)
FTP_REMOTE_DIR=/www/guide
FTP_SITEMAP_DIR=/www

# 공개 사이트 URL (IndexNow host / canonical)
SITE_URL=https://www.example.com
BRAND_NAME=아가펫보호소
PHONE=010-0000-0000

# IndexNow (네이버 Search Advisor)
# 키 파일({KEY}.txt)을 사이트 루트에 미리 올려 두세요.
INDEXNOW_KEY=replace-with-indexnow-key
INDEXNOW_HOST=www.example.com
INDEXNOW_KEY_LOCATION=https://www.example.com/replace-with-indexnow-key.txt
INDEXNOW_ENDPOINT=https://searchadvisor.naver.com/indexnow

OUTPUT_DIR=./output
